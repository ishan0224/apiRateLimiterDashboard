# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Environment / Secrets ────────────────────────────────────────────────────
.env*
!.env.example

# ── Markdown (internal notes / docs) ─────────────────────────────────────────
# Keep only the root README; all other .md files (incl. *.notes.md) are ignored
*.md
!README.md
!readme.md
!Readme.md
**/README.md
**/readme.md
**/Readme.md

# ── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
build/

# ── Lambda / deployment artefacts ────────────────────────────────────────────
*.zip
.lambda-build/
lambda-package/

# ── SST ──────────────────────────────────────────────────────────────────────
.sst/

# ── Prisma generated client ───────────────────────────────────────────────────
# The generated client is produced at build time; never commit it
**/node_modules/.prisma/

# ── SST type stubs (auto-generated per developer environment) ─────────────────
sst-env.d.ts
**/sst-env.d.ts

# ── TypeScript incremental build info ────────────────────────────────────────
*.tsbuildinfo

# ── Test coverage ────────────────────────────────────────────────────────────
coverage/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Caches ───────────────────────────────────────────────────────────────────
.turbo/
.cache/
.eslintcache

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
